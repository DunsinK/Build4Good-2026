{
  "description": "Normalised response contract between backend and mobile app.",

  "rest": {
    "GET /health": {
      "response": {
        "status": "ok"
      }
    }
  },

  "websocket": {
    "endpoint": "/ws/referee",

    "client_sends": [
      "Raw binary bytes (JPEG/PNG)",
      "Base64-encoded string (with or without data:image prefix)",
      "JSON text with a \"frame\" key containing base64 data"
    ],

    "server_sends": "WebSocketResponse (see schema below)"
  },

  "schema": {
    "WebSocketResponse": {
      "type": {
        "type": "string",
        "enum": ["tracking", "decision", "error", "connected"],
        "description": "tracking = normal frame, decision = rally-ending event, error = decode/processing failure, connected = initial handshake"
      },
      "frame_index": {
        "type": "integer | null",
        "description": "Monotonically increasing frame counter for the session"
      },
      "ball_detected": {
        "type": "boolean",
        "description": "Whether the ball was found in this frame"
      },
      "ball_position": {
        "type": "object | null",
        "properties": {
          "x": { "type": "integer" },
          "y": { "type": "integer" }
        },
        "description": "Pixel coordinates of the ball, or null if not detected"
      },
      "court_detected": {
        "type": "boolean",
        "description": "Whether the court boundary polygon has been established"
      },
      "bounce_detected": {
        "type": "boolean",
        "description": "Whether a bounce was detected on this frame"
      },
      "call": {
        "type": "string | null",
        "enum": ["IN", "OUT", null],
        "description": "Line call if a bounce was detected"
      },
      "point_awarded_to": {
        "type": "string | null",
        "enum": ["left", "right", null],
        "description": "Which side won the point, or null if rally is ongoing"
      },
      "audio_text": {
        "type": "string | null",
        "enum": ["left got the point", "right got the point", null],
        "description": "Minimal text for audio announcement"
      },
      "confidence": {
        "type": "number",
        "description": "Confidence score for the most recent detection (0.0 – 1.0)"
      },
      "message": {
        "type": "string | null",
        "description": "Human-readable status or error message"
      }
    }
  },

  "examples": {
    "connected": {
      "type": "connected",
      "frame_index": null,
      "ball_detected": false,
      "ball_position": null,
      "court_detected": false,
      "bounce_detected": false,
      "call": null,
      "point_awarded_to": null,
      "audio_text": null,
      "confidence": 0.0,
      "message": "Engine ready — start streaming frames"
    },

    "tracking_ball_found": {
      "type": "tracking",
      "frame_index": 42,
      "ball_detected": true,
      "ball_position": { "x": 320, "y": 480 },
      "court_detected": true,
      "bounce_detected": false,
      "call": null,
      "point_awarded_to": null,
      "audio_text": null,
      "confidence": 0.0,
      "message": null
    },

    "tracking_ball_missing": {
      "type": "tracking",
      "frame_index": 43,
      "ball_detected": false,
      "ball_position": null,
      "court_detected": true,
      "bounce_detected": false,
      "call": null,
      "point_awarded_to": null,
      "audio_text": null,
      "confidence": 0.0,
      "message": "Ball not detected"
    },

    "decision_point_awarded": {
      "type": "decision",
      "frame_index": 87,
      "ball_detected": true,
      "ball_position": { "x": 310, "y": 475 },
      "court_detected": true,
      "bounce_detected": true,
      "call": "OUT",
      "point_awarded_to": "right",
      "audio_text": "right got the point",
      "confidence": 0.92,
      "message": "Rally ended (ball_out) — point candidate: right"
    },

    "error": {
      "type": "error",
      "frame_index": 88,
      "ball_detected": false,
      "ball_position": null,
      "court_detected": false,
      "bounce_detected": false,
      "call": null,
      "point_awarded_to": null,
      "audio_text": null,
      "confidence": 0.0,
      "message": "Failed to decode image frame"
    }
  }
}
